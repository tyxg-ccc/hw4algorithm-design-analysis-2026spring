      "# add your code here\n",
      "# 3.使用 Python 实现题目的算法,在这里使用归并排序\n",
      "def efficient_sort(arr):\n",
      "    if len(arr) <= 1:\n",
      "        return arr\n",
      "    \n",
      "    # 分治 (Divide)\n",
      "    mid = len(arr) // 2\n",
      "    left = efficient_sort(arr[:mid])\n",
      "    right = efficient_sort(arr[mid:])\n",
      "    \n",
      "    # 合并 (Conquer)\n",
      "    return merge(left, right)\n",
      "\n",
      "def merge(left, right):\n",
      "    merged = []\n",
      "    i = j = 0\n",
      "    while i < len(left) and j < len(right):\n",
      "        if left[i] <= right[j]:\n",
      "            merged.append(left[i])\n",
      "            i += 1\n",
      "        else:\n",
      "            merged.append(right[j])\n",
      "            j += 1\n",
      "            \n",
      "    merged.extend(left[i:])\n",
      "    merged.extend(right[j:])\n",
      "    return merged\n",
      "\n",
      "# 测试例子\n",
      "# test_array = [8, 3, 2, 7, 4, 1, 5, 9, 6]\n",
      "# print(\"Sorted:\", efficient_sort(test_array))\n",
      "# 输出结果\n",
      "# Sorted:1,2,3,4,5,6,7,8,9\n",
      "\n",
      "# your algorithm time complexity is: O(n log n)\n"
