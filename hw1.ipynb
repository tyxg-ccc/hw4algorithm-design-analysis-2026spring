      "def max_profit(profits):\n",
      "    max_sum = float('-inf')\n",
      "    current_sum = 0\n",
      "    buy_day = 0\n",
      "    best_buy = 0\n",
      "    best_sell = 0\n",
      "    \n",
      "    for i, profit in enumerate(profits):\n",
      "        if current_sum <= 0:\n",
      "            current_sum = profit\n",
      "            buy_day = i + 1  # 记录买入的天数（题目中为从1开始的序号）\n",
      "        else:\n",
      "            current_sum += profit\n",
      "            \n",
      "        if current_sum > max_sum:\n",
      "            max_sum = current_sum\n",
      "            best_buy = buy_day\n",
      "            best_sell = i + 1\n",
      "            \n",
      "    return best_buy, best_sell, max_sum\n",
